# Database (Docker Compose - 로컬 개발)
MYSQL_ROOT_PASSWORD=test
MYSQL_USER=test
MYSQL_PASSWORD=test
MYSQL_DATABASE=foreign_api_sample
MYSQL_PORT=3306

# Spring Datasource (애플리케이션 실행)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/foreign_api_sample?useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=test
SPRING_DATASOURCE_PASSWORD=test

# JPA (애플리케이션 실행)
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=true

# Test Datasource (테스트 실행 - Testcontainers)
TEST_DATASOURCE_URL=jdbc:tc:mysql:8.0:///foreign_api_sample
TEST_DATASOURCE_DRIVER=org.testcontainers.jdbc.ContainerDatabaseDriver

# Test JPA (테스트 실행)
TEST_JPA_HIBERNATE_DDL_AUTO=validate
TEST_JPA_SHOW_SQL=false

# Mock Worker (외부 이미지 처리 서비스)
MOCK_WORKER_BASE_URL=https://dev.realteeth.ai/mock
MOCK_WORKER_CANDIDATE_NAME=scv74502
MOCK_WORKER_EMAIL=scv74502@gmail.com
